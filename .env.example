# La aplicación funciona en modo local cuando estas variables quedan vacías.
# Utiliza únicamente la clave publicable del proyecto Supabase.
# Nunca añadas service_role, secret key ni contraseñas al frontend.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_ISIVOLT_WORKSPACE_ID=

# Punto de entrega físico opcional.
# Déjalo desactivado hasta instalar el servicio firmado en el mini PC.
# Valores admitidos: disabled | signed-qr
VITE_ISIVOLT_STATION_MODE=disabled
VITE_ISIVOLT_STATION_ID=ALMACEN-PRINCIPAL
# Clave pública JWK ECDSA P-256 en una sola línea. La clave privada permanece únicamente en el mini PC.
VITE_ISIVOLT_STATION_PUBLIC_KEY_JWK=
# Tolerancia de reloj y duración máxima aceptada para cada QR rotatorio.
VITE_ISIVOLT_STATION_CLOCK_SKEW_SECONDS=10
VITE_ISIVOLT_STATION_MAX_TOKEN_SECONDS=90
