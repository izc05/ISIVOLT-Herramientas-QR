STATION_ID=ALMACEN-PRINCIPAL
STATION_HOST=0.0.0.0
STATION_PORT=8787
STATION_TOKEN_SECONDS=45
STATION_ROTATION_SECONDS=30
STATION_CLOCK_SKEW_SECONDS=10
STATION_MAX_TOKEN_SECONDS=90

# Orígenes web autorizados para consultar y canjear pases.
# Separa varios mediante comas.
STATION_ALLOWED_ORIGINS=https://izc05.github.io

# Las rutas relativas se resuelven desde station-service.
STATION_KEY_DIRECTORY=./data/keys
STATION_AUDIT_PATH=./data/redemptions.jsonl

# Para canje reforzado desde una web HTTPS, configura ambos archivos.
# Deben pertenecer a un certificado reconocido por los móviles.
STATION_TLS_CERT=
STATION_TLS_KEY=
